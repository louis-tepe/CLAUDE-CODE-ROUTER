# Mode: Hybride GLM (Sonnet -> GLM-5.1, Haiku -> GLM-4.7)
# Shell directives (not passed to proxy)
_SHELL_SONNET_KEY=.zai-api-key
_SHELL_HAIKU_KEY=.zai-api-key
_SHELL_DISABLE_CACHING_SONNET=1
_SHELL_DISABLE_CACHING_HAIKU=1

# Proxy env vars
SONNET_PROVIDER_BASE_URL=https://api.z.ai/api/anthropic
HAIKU_PROVIDER_BASE_URL=https://api.z.ai/api/anthropic
PROVIDER_SONNET_MODEL=glm-5.1
PROVIDER_HAIKU_MODEL=glm-4.7
